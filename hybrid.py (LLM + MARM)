        "infer": infer,
        "unsure": unsure,
        "critique": out["critique"].item()
    }


def hybrid_decision(answer: str):
    """Legacy function for hybrid decision making."""
    score = evaluate_answer(answer)

    if score["unsure"] > 0.45 or score["critique"] < 0.4:
        return {
            "decision": "ABSTAIN",
            "epistemic": score
        }

    return {
        "decision": "ACCEPT",
        "epistemic": score
    }


