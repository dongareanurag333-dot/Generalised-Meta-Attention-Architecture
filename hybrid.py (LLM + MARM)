    """Legacy function for answer evaluation."""
    tokens = tokenizer(
        answer,
        return_tensors="pt",
        truncation=True,
        padding=True
    )["input_ids"].to(device)

    with torch.no_grad():
        out = marm(tokens)

    know, infer, unsure = out["epistemic"][0].tolist()

    return {
